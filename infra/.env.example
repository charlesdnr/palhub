# Secrets de prod (docker-compose.prod.yml). Copier en .env et remplir.
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-me
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Origine publique du site, sans slash final (sert aussi au callback Discord)
PUBLIC_ORIGIN=https://palhub.example.com

# Sync hébergée (facultatif — laisser vide si non utilisée).
# Secret partagé avec le runner GitHub Actions (≥ 32 caractères) :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WORKER_SECRET=
# Clé de chiffrement des identifiants SFTP : EXACTEMENT 64 caractères hex :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SYNC_ENC_KEY=
