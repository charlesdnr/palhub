generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String         @id @default(uuid()) @db.Uuid
  discordId   String         @unique @map("discord_id")
  username    String
  avatarUrl   String?        @map("avatar_url")
  /// Incrémenté à la déconnexion globale : invalide tous les JWT émis avant.
  tokenVersion Int           @default(0) @map("token_version")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  servers     Server[]
  memberships ServerMember[]

  @@map("users")
}

model Server {
  id           String     @id @default(uuid()) @db.Uuid
  ownerId      String     @map("owner_id") @db.Uuid
  owner        User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  slug         String     @unique
  name         String
  description  String?
  apiKeyHash   String?    @map("api_key_hash")
  apiKeyPrefix String?    @unique @map("api_key_prefix")
  /// Verrouillé au premier ingest : refuse ensuite les payloads d'un autre monde
  worldId      String?    @map("world_id")
  /// 'public' (annuaire + accessible), 'unlisted' (accessible par lien seul),
  /// 'private' (carte/palbox refusés à qui n'est pas membre)
  visibility   String     @default("unlisted")
  lastIngestAt DateTime?  @map("last_ingest_at") @db.Timestamptz()
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  snapshots    Snapshot[]
  syncConfig   SyncConfig?
  members      ServerMember[]
  invite       ServerInvite?

  @@map("servers")
}

/// Co-admins invités par le propriétaire : gèrent synchro et description,
/// mais ni la clé API ni la suppression.
model ServerMember {
  serverId  String   @map("server_id") @db.Uuid
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@id([serverId, userId])
  @@map("server_members")
}

/// Un seul lien d'invitation actif par serveur (regénérer = invalider l'ancien).
model ServerInvite {
  token     String   @id
  serverId  String   @unique @map("server_id") @db.Uuid
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("server_invites")
}

/// Synchro hébergée : la plateforme tire le Level.sav en SFTP à la place de l'admin.
model SyncConfig {
  serverId      String    @id @map("server_id") @db.Uuid
  server        Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  host          String
  port          Int       @default(22)
  username      String
  /// 'password' ou 'key'
  authType      String    @map("auth_type")
  /// mot de passe ou clé privée, chiffré AES-256-GCM (iv:tag:données, base64)
  secretEnc     String    @map("secret_enc")
  /// dossier du monde : /Pal/Saved/SaveGames/0/<WorldID>
  remotePath    String    @map("remote_path")
  enabled       Boolean   @default(true)
  /// Empreinte SHA256 de la clé d'hôte SSH, mémorisée à la 1re connexion (TOFU) :
  /// le runner refuse ensuite de se connecter si elle change. Réinitialisée
  /// quand host/port change.
  hostKeyFp     String?   @map("host_key_fp")
  /// Verrou de distribution : posé quand un runner réclame ce job, expire après
  /// 10 min. Limite l'exposition — un appel ne rend qu'un secret à la fois.
  claimedAt     DateTime? @map("claimed_at") @db.Timestamptz()
  lastRunAt     DateTime? @map("last_run_at") @db.Timestamptz()
  /// 'ok' | 'unchanged' | 'error'
  lastStatus    String?   @map("last_status")
  lastError     String?   @map("last_error")
  lastStatSize  BigInt?   @map("last_stat_size")
  lastStatMtime BigInt?   @map("last_stat_mtime")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@map("sync_configs")
}

model Snapshot {
  id          BigInt   @id @default(autoincrement())
  serverId    String   @map("server_id") @db.Uuid
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  /// 'palbox' (historisé, purge aux 30 derniers) ou 'live' (upsert, 1 seul enregistrement)
  kind        String
  sourceHash  String   @map("source_hash")
  generatedAt DateTime @map("generated_at") @db.Timestamptz()
  payload     Json
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([serverId, kind, sourceHash])
  @@index([serverId, kind, generatedAt(sort: Desc)])
  @@map("snapshots")
}
