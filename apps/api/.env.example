# Copier en .env et remplir.
DATABASE_URL=postgresql://palhub:palhub@localhost:5432/palhub

# Secret de signature des JWT (générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change-me

# App Discord (https://discord.com/developers/applications → OAuth2)
# Redirect à déclarer côté Discord : http://localhost:3000/api/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3000/api/auth/discord/callback

# Origine du front (redirections post-login + CORS en dev)
WEB_ORIGIN=http://localhost:4200

# Sync hébergée : secret partagé avec le runner (GitHub Actions) et clé de
# chiffrement des identifiants SFTP (générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
WORKER_SECRET=
SYNC_ENC_KEY=
