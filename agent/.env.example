# Copier en .env à côté de l'agent, puis remplir.

# L'API PalHub et la clé de TON serveur (générée dans « Mes serveurs » sur le site)
PALHUB_API_URL=http://localhost:3000
PALHUB_API_KEY=pal_xxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Source du Level.sav : un chemin local…
PALHUB_SOURCE=C:/PalServer/Pal/Saved/SaveGames/0/VOTRE_WORLD_ID
# …ou sftp:// (et dans ce cas les variables suivantes)
#PALHUB_SOURCE=sftp://
#PALHUB_SRC_HOST=game-nodeXX.hebergeur.fr
#PALHUB_SRC_PORT=2022
#PALHUB_SRC_USER=email+suffixe
#PALHUB_SRC_KEY=C:/Users/moi/.ssh/palhub_agent
#PALHUB_SRC_PATH=/Pal/Saved/SaveGames/0/VOTRE_WORLD_ID
