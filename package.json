{
  "name": "palhub",
  "version": "0.1.0",
  "private": true,
  "description": "Plateforme multi-serveurs Palworld : carte interactive + palbox explorer",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:shared": "npm run build -w @palhub/shared",
    "dev:api": "npm run start:dev -w api",
    "dev:web": "npm run start -w web",
    "build": "npm run build:shared && npm run build -w api && npm run build -w web"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "prisma@6.19.3": true,
    "unrs-resolver@1.12.2": true,
    "@parcel/watcher@2.5.6": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true
  },
  "optionalDependencies": {
    "@lmdb/lmdb-win32-x64": "^3.5.6",
    "@rollup/rollup-win32-x64-msvc": "^4.62.2",
    "lmdb": "^3.5.6"
  }
}
